{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EliteCleaner",
  "version": "1.0.0",
  "identifier": "com.elitecleaner.app",
  "build": {
    "frontendDist": "../static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "1337 Cleaner",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true,
        "backgroundColor": "#080808"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "EliteCleaner — 1337 system cleanup tool",
    "longDescription": "EliteCleaner (1337 Cleaner) — advanced desktop tool for hidden Java app launch with Steam environment emulation and system cleanup.",
    "resources": [
      "../scripts/**/*",
      "../templates/**/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
